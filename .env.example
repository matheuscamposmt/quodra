# Public origin where the app is served (no trailing slash). Builds /s/<slug> URLs.
NUXT_PUBLIC_SITE_URL=http://localhost:3001

# Linear personal API key — Linear → Settings → API → Personal API keys.
NUXT_LINEAR_API_KEY=

# Password to access the admin panel.
NUXT_ADMIN_PASSWORD=

# Seals the http-only session cookie. Minimum 32 chars.  openssl rand -hex 32
NUXT_SESSION_PASSWORD=

# Postgres. docker-compose sets this for you locally.
NUXT_DATABASE_URL=postgres://postgres:postgres@localhost:5432/quodra
